# =============================================================================
# job-hunt-os environment variables
# Copy this file to `.env` (in the repo root) and to `infrastructure/.env`,
# then fill in your own values. Never commit `.env`.
# =============================================================================

# --- NocoDB (data backend) ---
# After `docker compose up -d` in infrastructure/, set up an admin user via the
# UI at http://localhost:8080, then create an API token in account settings.
NOCODB_URL=http://localhost:8080
NOCODB_API_TOKEN=
NOCODB_BASE_ID=

# --- OpenRouter (mock interview LLM, recruiter review, optional resume rewrites) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- GitHub (used by session-start to pull, session-end to push) ---
# Personal access token with `repo` scope. Stored locally only.
GITHUB_PAT=
GITHUB_USERNAME=
GITHUB_REPO=

# --- Active user ---
# Slug of the user this session is operating on. Multi-user support is optional;
# leave as `default` for solo use. Per-user data lives at:
#   applications/<slug>/, interviews/<slug>/, outreach/<slug>/, research/<slug>/,
#   applications/resumes/data/<slug>/
JOB_HUNT_USER=default

# --- Optional: LinkedIn MCP ---
# If you use the LinkedIn scraper MCP, store your session cookie via
# `uvx linkedin-scraper-mcp --login` rather than putting it here.

# --- Optional: Tailscale (private VPN access to your NocoDB on a remote VPS) ---
# Only needed if you host NocoDB on a remote machine and want private access.
TAILSCALE_NOCODB_URL=

# --- Optional: Hunter.io / Lusha (contact enrichment) ---
HUNTER_API_KEY=
LUSHA_API_KEY=
