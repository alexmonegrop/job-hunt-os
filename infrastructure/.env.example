# =============================================================================
# infrastructure/.env.example
# Copy to infrastructure/.env and fill in values before `docker compose up -d`.
# =============================================================================

# Required — Postgres password used by both `postgres` and `nocodb` services.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_TO_A_GENERATED_PASSWORD

# Optional — host port to expose NocoDB on. Default 8080.
NOCODB_HOST_PORT=8080

# Optional — domain for the Caddy reverse proxy. Only used when running with
# `--profile caddy`. Default db.localhost (works for local testing only).
# For a public deployment, set to your real domain (e.g., db.example.com).
NOCODB_DOMAIN=db.localhost
